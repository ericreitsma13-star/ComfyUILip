{
  "_comment": "LatentSync MV pipeline config — local paths for ericr machine",

  "comfyui": {
    "url": "http://127.0.0.1:8188",
    "input_dir": "/home/ericr/ComfyUI/input",
    "output_dir": "/home/ericr/ComfyUI/output"
  },

  "workflows": {
    "base_singer_ltx": "workflows/01_base_singer_LTX_IPAdapter_api.json",
    "base_singer_wan": "workflows/02_base_singer_Wan_IPAdapter_api.json",
    "broll_ltx":       "workflows/03_broll_render_LTX_api.json",
    "broll_wan":       "workflows/04_broll_render_Wan_api.json",
    "latentsync":      "workflows/05_latentsync_apply_api.json",
    "postfx_singer":   "workflows/06_face_restore_postfx_api.json",
    "postfx_broll":    "workflows/07_standard_postfx_api.json"
  },

  "llm": {
    "provider": "ollama",
    "model": "llama3.1:70b",
    "send_images": false,
    "temperature": 0.8,
    "max_tokens": 10000
  },

  "vocal_isolation": {
    "model": "htdemucs",
    "device": "cuda",
    "shifts": 1,
    "save_stems": false
  },

  "render": {
    "use_postfx": false,
    "seed_offset": 0,
    "poll_interval_sec": 3.0,
    "per_job_timeout_sec": 1800
  },

  "assemble": {
    "width": 1920,
    "height": 1080,
    "fps": 48,
    "title": "Untitled",
    "artist": "Unknown Artist",
    "render_social_variants": true,
    "srt_path": null
  },

  "models": {
    "_comment_latentsync": "LatentSync 1.6 — installed in custom_nodes/ComfyUI-LatentSyncWrapper/checkpoints/",
    "latentsync_unet": "custom_nodes/ComfyUI-LatentSyncWrapper/checkpoints/latentsync_unet.pt",
    "latentsync_syncnet": "custom_nodes/ComfyUI-LatentSyncWrapper/checkpoints/stable_syncnet.pt",
    "latentsync_whisper": "custom_nodes/ComfyUI-LatentSyncWrapper/checkpoints/whisper/tiny.pt",
    "latentsync_vae": "custom_nodes/ComfyUI-LatentSyncWrapper/checkpoints/vae/",

    "_comment_broll": "B-roll models (LTX 2.3 + Wan 2.1 14B GGUF)",
    "ltx_checkpoint": "models/checkpoints/ltx-2.3-22b-distilled-1.1.safetensors",
    "ltx_vae": "models/vae/ltx-2.3-22b-distilled_video_vae.safetensors",
    "ltx_audio_vae": "models/vae/ltx-2.3-22b-distilled_audio_vae.safetensors",
    "ltx_text_encoder": "models/clip/ltx-2-3-22b-text_encoder.safetensors",
    "wan_unet": "models/unet/wan2.1-i2v-14b-480p-Q4_K_M.gguf",
    "wan_clip": "models/clip/umt5_xxl_fp8.safetensors",
    "wan_vae": "models/vae/wan_2.1_vae.safetensors",

    "_comment_ipadapter": "IP-Adapter FaceID PlusV2 SDXL + CLIP vision",
    "ipadapter_faceid": "models/ipadapter/ip-adapter-faceid-plusv2_sdxl.bin",
    "clip_vision": "models/clip_vision/CLIP-ViT-H-14-laion2B-s32B-b79K.safetensors",

    "_comment_postfx": "Post-FX models (CodeFormer + RIFE + 4x upscale)",
    "upscale_model": "models/upscale_models/4x-UltraSharp.pth",
    "rife_model": "models/rife/rife47.pth",
    "codeformer": "models/facerestore_models/codeformer.pth",
    "lut_file": null
  },

  "comfyui_launch_args": [
    "--enable-cors-header",
    "--lowvram",
    "--use-flash-attention",
    "--cache-none"
  ]
}
